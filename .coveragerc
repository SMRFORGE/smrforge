[run]
source = smrforge
omit = 
    */tests/*
    */test_*.py
    */__pycache__/*
    */site-packages/*
    */venv/*
    */env/*
    setup.py
    # Standard exclusions (see pytest.ini / COVERAGE_TRACKING.md)
    */examples/*
    */gui/*
    */visualization/*
    */cli.py
    */convenience/transients.py
    */safety/transients.py
    */uncertainty/uq.py
    */core/endf_parser.py
    */core/endf_extractors.py
    */core/thermal_scattering_parser.py
    */core/photon_parser.py
    */core/gamma_production_parser.py
    */core/energy_angle_parser.py
    */core/fission_yield_parser.py
    */core/decay_parser.py
    */core/temperature_interpolation.py
    */neutronics/hybrid_solver.py
    */neutronics/adaptive_sampling.py
    */neutronics/monte_carlo_optimized.py
    */neutronics/implicit_mc.py
    */geometry/advanced_import.py
    */data_downloader.py
    */geometry/validation.py
    */burnup/lwr_burnup.py
    */convenience.py
    */convenience/__init__.py
    */economics/integration.py
    */burnup/fuel_management_integration.py
    */utils/parallel_batch.py
    */control/integration.py
    */core/decay_chain_utils.py
    */core/multigroup_advanced.py
    */core/self_shielding_integration.py
    */core/endf_setup.py

[report]
precision = 1
show_missing = True
skip_covered = False
fail_under = 90

# Exclude lines from coverage reports with explanations
exclude_lines =
    # JIT-compiled functions use pragma: no cover in the code
    # See COVERAGE_EXCLUSIONS.md for details
    
    # Example/demo code: Not production code
    if __name__ == .__main__.:
    
    # Type checking and protocol methods
    @.*protocol|@.*overload

[html]
directory = htmlcov
title = SMRForge Test Coverage

